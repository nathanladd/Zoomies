[Unit]
Description=Rudi Game Server
After=network.target

[Service]
Type=simple
User=rudi
Group=rudi
WorkingDirectory=/opt/rudi
ExecStart=/opt/rudi/venv/bin/uvicorn server.main:app --host 127.0.0.1 --port 5000
Restart=on-failure
RestartSec=5
Environment=RUDI_DATA_DIR=/opt/rudi/data

[Install]
WantedBy=multi-user.target
