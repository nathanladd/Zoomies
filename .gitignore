# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# Data directory — all runtime files ignored, only the directory placeholder is tracked
data/*
!data/.gitkeep

# The .gitkeep is a dummy empty file whose only purpose is to keep the folder itself in git 
# — otherwise git wouldn't track an empty directory at all.

# Uploaded media (keep directory structure)
media/questions/*
!media/questions/.gitkeep

# Backups
backups/

# PyInstaller / installer build artifacts
dist/
build/
*.manifest
*.spec.bak

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
*.err

# Releases — built locally, not tracked in git
releases/

# Secrets and local runtime files
jwt_secret.txt
credentials.json
connection.json
database/

# OS
Thumbs.db
.DS_Store
